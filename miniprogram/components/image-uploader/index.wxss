.image-uploader {
  display: inline-block;
}

.image-uploader__media {
  width: 100%;
  height: 100%;
}

.image-uploader__avatar-button {
  padding: 0;
  margin: 0;
  border: 0;
  background: transparent;
  line-height: normal;
}

.image-uploader__avatar-button::after {
  border: 0;
}

.image-uploader__custom-trigger {
  display: block;
  width: 100%;
  height: 100%;
}

.weui-uploader__input-box {
  width: 100%;
  height: 100%;
  border: 1px solid #f2f2f2;
  position: relative;
  background-color: #fff;
  border-radius: 10rpx;
  box-sizing: border-box;
}

.weui-uploader__input-box:before,
.weui-uploader__input-box:after {
  content: " ";
  position: absolute;
  background-color: #ccc;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.weui-uploader__input-box:before {
  width: 2px;
  height: 40%;
}

.weui-uploader__input-box:after {
  width: 40%;
  height: 2px;
}

.image-uploader__list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-uploader__item,
.image-uploader__add {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #f7f8fa;
}

.image-uploader__preview,
.image-uploader__placeholder {
  width: 100%;
  height: 100%;
}

.image-uploader__delete {
  position: absolute;
  top: 0;
  right: 0;
  width: 36rpx;
  height: 36rpx;
  line-height: 34rpx;
  text-align: center;
  color: #fff;
  background: rgba(0, 0, 0, .65);
  border-radius: 0 0 0 18rpx;
  font-size: 28rpx;
}
