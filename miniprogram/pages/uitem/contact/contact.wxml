<view class="page">
  <view class="header">
    <view class="title">帮助与反馈</view>
    <view class="subtitle">如遇到使用问题，请通过站内反馈入口提交说明。</view>
  </view>

  <view class="section">
    <block wx:for="{{serviceItems}}" wx:key="title">
      <view class="item">
        <view class="item-title">{{item.title}}</view>
        <view class="item-desc">{{item.desc}}</view>
      </view>
    </block>
  </view>

  <view class="actions">
    <van-button type="primary" block round bind:tap="toSuggestion">提交意见反馈</van-button>
    <van-button custom-class="secondary-button" block round bind:tap="copyHelpText">复制反馈说明</van-button>
  </view>
</view>
