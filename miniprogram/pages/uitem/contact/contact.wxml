<view class="page">
  <view class="header">
    <view class="title">帮助与反馈</view>
    <view class="subtitle">如遇到使用问题，可以添加客服微信或通过站内反馈入口提交说明。</view>
  </view>

  <view class="wechat-card">
    <view class="wechat-title">联系我们</view>
    <view class="wechat-desc">扫码添加客服微信，反馈使用问题或咨询平台相关事项。</view>
    <image
      class="wechat-qr"
      src="{{wechatQr}}"
      mode="widthFix"
      show-menu-by-longpress="{{true}}"
      bindtap="previewWechatQr"
    ></image>
    <view class="wechat-tip">点击二维码可放大查看</view>
  </view>

  <view class="repo-card">
    <view class="repo-title">开源仓库</view>
    <view class="repo-desc">小程序端无法直接跳转外部网页，可复制链接后在浏览器中打开。</view>
    <block wx:for="{{repos}}" wx:key="url">
      <view class="repo-item">
        <view class="repo-main">
          <view class="repo-name">{{item.name}}</view>
          <view class="repo-url" selectable="true">{{item.url}}</view>
        </view>
        <van-button
          type="primary"
          size="small"
          round
          data-url="{{item.url}}"
          bind:tap="copyRepoLink"
        >复制</van-button>
      </view>
    </block>
  </view>

  <view class="section">
    <block wx:for="{{serviceItems}}" wx:key="title">
      <view class="item">
        <view class="item-title">{{item.title}}</view>
        <view class="item-desc">{{item.desc}}</view>
      </view>
    </block>
  </view>

  <view class="actions">
    <van-button type="primary" block round bind:tap="toSuggestion">提交意见反馈</van-button>
    <van-button custom-class="secondary-button" block round bind:tap="copyHelpText">复制反馈说明</van-button>
  </view>
</view>
