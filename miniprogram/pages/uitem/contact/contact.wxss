.page {
  min-height: 100vh;
  padding: 32rpx 28rpx;
  background: #f7f8fa;
  box-sizing: border-box;
}

.header {
  padding: 28rpx 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #202124;
}

.subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #70757a;
}

.wechat-card {
  margin-top: 24rpx;
  padding: 28rpx 24rpx 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-sizing: border-box;
  text-align: center;
}

.wechat-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #202124;
  text-align: left;
}

.wechat-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #5f6368;
  text-align: left;
}

.wechat-qr {
  width: 76%;
  max-width: 480rpx;
  margin-top: 24rpx;
  border-radius: 12rpx;
}

.wechat-tip {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #9aa0a6;
}

.repo-card {
  margin-top: 24rpx;
  padding: 28rpx 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.repo-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #202124;
}

.repo-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #5f6368;
}

.repo-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 22rpx;
  margin-top: 22rpx;
  border-top: 1rpx solid #eef0f2;
}

.repo-main {
  flex: 1;
  min-width: 0;
  padding-right: 18rpx;
}

.repo-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #202124;
}

.repo-url {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.4;
  color: #70757a;
  word-break: break-all;
}

.section {
  margin-top: 24rpx;
}

.item {
  padding: 24rpx;
  margin-bottom: 18rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.item-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #202124;
}

.item-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #5f6368;
}

.actions {
  margin-top: 28rpx;
}

.secondary-button {
  margin-top: 18rpx;
  color: #4b5563 !important;
  background: #ffffff !important;
  border-color: #e5e7eb !important;
}
