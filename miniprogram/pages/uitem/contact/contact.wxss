.page {
  min-height: 100vh;
  padding: 32rpx 28rpx;
  background: #f7f8fa;
  box-sizing: border-box;
}

.header {
  padding: 28rpx 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #202124;
}

.subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #70757a;
}

.section {
  margin-top: 24rpx;
}

.item {
  padding: 24rpx;
  margin-bottom: 18rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.item-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #202124;
}

.item-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #5f6368;
}

.actions {
  margin-top: 28rpx;
}

.secondary-button {
  margin-top: 18rpx;
  color: #4b5563 !important;
  background: #ffffff !important;
  border-color: #e5e7eb !important;
}
